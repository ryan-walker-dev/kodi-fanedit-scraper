<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Addon settings for metadata.fanedit.org
  Kodi 19+ (Matrix / Nexus / Omega) settings format.

  String IDs used here must match those defined in
  resources/language/English/strings.po.
-->
<settings>
  <section id="google_api">
    <category id="general" label="32000">

      <group id="1" label="32010">
        <setting id="google_api_key" type="string" label="32001">
          <level>0</level>
          <default></default>
          <constraints>
            <allowempty>true</allowempty>
          </constraints>
        </setting>

        <setting id="google_cx" type="string" label="32002">
          <level>0</level>
          <default></default>
          <constraints>
            <allowempty>true</allowempty>
          </constraints>
        </setting>
      </group>

      <group id="2" label="32011">
        <setting id="max_results" type="integer" label="32003">
          <level>1</level>
          <default>10</default>
          <constraints>
            <minimum>1</minimum>
            <maximum>10</maximum>
            <step>1</step>
          </constraints>
          <control type="spinner"/>
        </setting>
      </group>

    </category>
  </section>
</settings>
