<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="metadata.fanedit.org" name="Fanedit.org Scraper" version="1.0.1" provider-name="ryan-walker-dev">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <!-- Movie metadata scraper extension point -->
  <extension point="xbmc.metadata.scraper.movies" library="default.py" settings="true">
    <provides>movies</provides>
  </extension>

  <!-- Addon metadata -->
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Fanedit.org movie scraper</summary>
    <description lang="en_GB">Scrapes fanedit.org for fan-edit movie details. Uses the Google Custom Search API to find titles; configure your API key and Custom Search Engine ID in the addon settings.</description>
    <news>1.0.1 - Fix settings page not appearing: correct settings attribute to boolean true and add version to settings.xml</news>
    <platform>all</platform>
    <license>MIT</license>
    <website>https://www.fanedit.org</website>
    <source>https://github.com/ryan-walker-dev/kodi-fanedit-scraper</source>
    <forum/>
    <email/>
  </extension>
</addon>
